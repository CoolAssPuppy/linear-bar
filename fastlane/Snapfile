# Snapfile for LinearBar screenshot automation
# Documentation: https://docs.fastlane.tools/actions/snapshot/

# Workspace and scheme
workspace nil  # We're using a project, not a workspace
project "./LinearBar.xcodeproj"
scheme "LinearBar"

# Test target containing the UI tests
testplan nil  # No test plan

# Output directory for screenshots
output_directory "./fastlane/screenshots"

# Clear previous screenshots before running
clear_previous_screenshots true

# macOS-specific settings
devices([
  "Mac"
])

# Languages to screenshot (add more if needed for localization)
languages([
  "en-US"
])

# Test target (the UI test bundle)
# Note: You'll need to specify this after adding the UI test target in Xcode
# test_target_name "LinearBarUITests"

# Enable concurrent simulator usage (macOS doesn't apply, but keeping for consistency)
concurrent_simulators false

# Stop after first failing test
stop_after_first_error false

# Skip opening the HTML summary at the end
skip_open_summary true

# Reinstall app before running tests
reinstall_app true

# Erase simulator before testing (macOS doesn't apply)
erase_simulator false

# Disable slide to type (iOS only, but keeping for reference)
disable_slide_to_type false

# Number of times to retry tests
number_of_retries 1

# Configuration specific to LinearBar
# The UI tests require manual interaction (clicking menu bar icon)
# So we use SimpleScreenshotTests which waits for manual clicks
